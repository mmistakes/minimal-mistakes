{
  "name": "Aging Health Research Portal",
  "image": "mcr.microsoft.com/devcontainers/ruby:3.2",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "bundle install && bundle lock --add-platform x86_64-linux",
  "customizations": {
    "vscode": {
      "extensions": [
        "rebornix.Ruby",
        "jekyll-theme-minimal-mistakes"
      ]
    }
  }
}
